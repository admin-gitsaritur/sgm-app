# SGM — Variáveis de Ambiente

# JWT Secret — chave para assinar tokens (OBRIGATÓRIO em produção)
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# CORS origin — URL permitida para requisições cross-origin
CORS_ORIGIN=http://localhost:3000

# Port — porta do servidor
PORT=3000

# Node env — production ou development
NODE_ENV=development

# Gemini API Key (opcional, para features de IA)
GEMINI_API_KEY=

# PostgreSQL Database (OBRIGATÓRIO)
DATABASE_URL=postgres://user:password@host:5432/database

# Google OAuth (opcional — login com Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin inicial (opcional — cria admin no primeiro boot se não existir)
ADMIN_EMAIL=
ADMIN_CPF=
ADMIN_NOME=
ADMIN_TELEFONE=
